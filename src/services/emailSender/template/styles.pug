style.
	body {
		color: rgba(0, 0, 0, 0.7);
		font-family: "Verdana", sans-serif;
		margin: 0;
		padding-top: 40px;
	}

	.wrapper {
		border-radius: 16px;
		margin-left: auto;
		margin-right: auto;
		max-width: 700px;
		overflow: hidden;
		padding: 20px;
	}

	h1, h3 {
		font-weight: bold;
		text-align: center;
	}

	h1 {
		font-size: 30px;
		margin-bottom: 0;
	}

	h2 {
		border-bottom: 3px solid #da2629;
		font-size: 20px;
		font-weight: 600;
		margin-bottom: 10px;
		margin-top: 22px;
		padding-bottom: 5px;
	}

	h3 {
		font-size: 18px;
	}

	h4 {
		font-size: 17px;
		margin-bottom: 10px;
	}

	p {
		font-size: 15px;
		font-weight: 500;
		margin-bottom: 12px;
		margin-top: 12px;
	}

	.link {
		color: #da2629 !important;
		font-weight: 600 !important;
		text-decoration: underline;
	}

	.link:hover {
		text-decoration: none;
	}

	img {
		display: inline-block;
		height: 100%;
	}

	.header {
		padding-top: 10px;
	}

	.header-logo {
		background-color: #4f8cff;
		border-radius: 4px;
		height: 19px;
		min-height: 19px;
  	display: block;
  	transform: rotate(45deg);
  	width: 19px;
	}

	.detail-value {
		display: inline-block;
		margin-left: 5px;
	}

	.price {
		background-color: rgba(0, 0, 0, .6);
		border-radius: 8px;
		color: white;
		margin-bottom: 20px;
		margin-top: 20px;
		padding-bottom: 10px;
		padding-right: 10px;
		padding-top: 10px;
		text-align: right;
	}

	.price-item {
		font-size: 22px;
		margin-bottom: 0;
		margin-top: 0;
	}